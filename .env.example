# gtm-engine — environment template  ·  LOCAL-DEV DOCUMENTATION ONLY
# =============================================================================
# Variables are grouped by TIER so you only set what your use case needs:
#
#   TIER 0 — required for ANY use (Claude Cowork skills, drafting, planning)
#   TIER 1 — optional; unlocks the content pipeline + richer research
#   TIER 2 — self-hosting / advanced only (VPS deployment, publishing, media)
#
# Claude Cowork users: you only need TIER 0 (ANTHROPIC_API_KEY). Run "set me up"
# and the agent handles the rest. Everything below TIER 0 is optional.
#
# This file is the canonical *catalog* of every variable the system reads — it is
# documentation, NOT how secrets reach a deployment. For self-hosting, secrets are
# injected by your secret manager (see docs/DEPLOY.md); this committed file holds
# only generic placeholders and is NEVER where real values live.
#
# Local dev:
#   cp .env.example .env        # .env is gitignored — NEVER commit it
#   # fill in the values, then load them into your shell:
#   set -a; source .env; set +a
#
# Keep this list in sync with agent/config.Config.from_env().
# =============================================================================


# =============================================================================
# TIER 0 — REQUIRED (the brain)
# =============================================================================
ANTHROPIC_API_KEY=          # REQUIRED — Claude Code / Agent SDK orchestrator. Nothing runs without this.


# =============================================================================
# TIER 1 — OPTIONAL (content pipeline + richer research; safe fallbacks exist)
# =============================================================================

# Worker model — cheap bulk first-drafts behind an MCP tool (Claude always reviews).
# Unset → the brain falls back to a Claude worker (works, just costs more).
DEEPSEEK_API_KEY=

# Firecrawl MCP — structured web scraping for research/market-scan/prospecting.
# Unset → skills fall back to the built-in keyless web tools (WebSearch/WebFetch),
# which are weaker but require no key. Vibe Prospecting is OAuth (no env key needed).
FIRECRAWL_API_KEY=

# Saleshandy MCP — email-sequence staging (in-repo wrapper agent/mcp/saleshandy).
# Auth is an x-api-key header; the key stays server-side and the brain never sees it.
# Unset → the email-sequence skill falls back to a manual, paste-ready plan.
# STAGING ONLY: the wrapper cannot activate or send a sequence (no resume tool exists) —
# a human flips it live in Saleshandy. See docs/prds/2026-07-13-email-sequence.md.
SALESHANDY_API_KEY=

# Per-run budget stop (USD). Hard SDK-level cap per run; mirrors PROFILE per_run_cap_usd.
PER_RUN_CAP_USD=10

# Optional model override (default: claude-sonnet-4-6); e.g. claude-opus-4-8 for heavy runs.
HERMES_MODEL=


# =============================================================================
# TIER 2 — SELF-HOSTING / ADVANCED ONLY
# Not needed for Claude Cowork. See docs/DEPLOY.md before setting these.
# Use generic placeholders below; real values belong in your secret manager or a
# gitignored .env / docker-compose.override.yml — never committed.
# =============================================================================

# --- Cockpit (Telegram bot) — only for an unattended self-hosted deployment ---
# In Cowork the chat IS the interface; you do NOT need a Telegram bot. To run the
# bot, create your OWN bot via @BotFather and use your own chat id.
TELEGRAM_BOT_TOKEN=         # your operator bot token (from @BotFather)
TELEGRAM_ALLOWED_CHAT_ID=   # whitelist: ONLY this chat_id may talk to / approve

# --- News feed (read-only Postgres over a `discovery_items` table) ---
# Optional. Unset → the radar uses the keyless web-sweep fallback automatically.
# Self-hosting only: point this at your own read-only DB role.
NEWS_DB_DSN=                # postgresql://user:password@host:5432/dbname

# --- Google Workspace (self-hosted CLI-MCP; personal account, least-privilege) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN= # least-privilege scopes; send/write only where needed

# --- Media (image + video; see docs/prds/2026-06-19-higgsfield-integration.md) ---
# REST/platform API auth is a key:secret PAIR (Authorization: Key <key>:<secret>); the
# MCP/CLI path uses account OAuth instead (no key). Pick one per the PRD.
HIGGSFIELD_API_KEY=         # REST access key
HIGGSFIELD_API_SECRET=      # REST secret (paired with the key)
ELEVENLABS_API_KEY=         # podcast voices (Phase 4) + cockpit voice TTS/STT
ELEVENLABS_VOICE_ID=        # optional; defaults to Fahco4VZzobUeiPqni1S (Archer — Conversational)

# --- Podcast agent engine (Phase 4, Mode B) ---
HERMES_ENDPOINT=            # orchestrator webhook → Transcript
HERMES_TOKEN=
# Hermes Mode B runs on DeepSeek (reuses DEEPSEEK_API_KEY)

# --- LinkedIn publish (Gate 2 — the ONLY outbound-posting path) ---
# Hermes posts ONLY by calling a dedicated n8n webhook that is write-only and has
# the target LinkedIn account PINNED server-side. Hermes therefore needs NO
# PostForMe key and NO account id — least privilege. The secret is a DEDICATED
# Hermes bearer (generate fresh: `openssl rand -hex 32`), never a shared secret.
# Publishing fires only after a human Approve in the cockpit. Default OFF.
HERMES_PUBLISH_URL=          # https://your-n8n-host/webhook/hermes-linkedin-publish
HERMES_PUBLISH_SECRET=       # dedicated bearer for Hermes ONLY (not a shared secret)
HERMES_PUBLISH_ENABLED=false # kill switch — capability stays OFF until set to true
# HERMES_PUBLISH_MAX_PER_HOUR=5   # optional client-side rate cap (default 5)
# HERMES_PUBLISH_MAX_CHARS=3000   # optional post length guard (default 3000)

# --- Publishing (PER-PROFILE — legacy placeholders; NOT used by Hermes) ---
# Hermes does NOT read these. The account-pinned webhook above is the only publish
# path; do NOT give Hermes a PostForMe API key (that would be over-privileged).
# One token pair per profile slug, e.g.:
# <PROFILE>_POSTFORME_TOKEN=
# <PROFILE>_YOUTUBE_TOKEN=

# --- Deck renderer sidecar (Slidev/Playwright/Chromium — headless export) ---
# Omit to keep deck export local (the skill falls back to the local guide). The
# deck-theme is baked into the sidecar image — no workspace path needed.
DECK_RENDERER_URL=http://deck-renderer:3000

# --- Default profile (session-bound; per-chat /profile overrides — no global switch) ---
ACTIVE_PROFILE=_template     # DEFAULT only; each chat binds its own profile
